# Audoctl Environment Configuration
# Copy this file to .env and adjust the values as needed
# Environment variables override config.yaml settings

# Config file path (optional)
AUDOCTL_CONFIG=config.development.yaml

# Database Configuration
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=audoctl
DB_PASSWORD=
DB_NAME=audoctl
DB_SSL_MODE=disable
DB_DSN=audoctl.db

# Application Configuration
NAME=Audoctl
VERSION=1.0.0

# Logging
LOG_LEVEL=info
LOG_ENV=production

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s
HTTP_BODY_LIMIT=10485760
HTTP_ENABLE_COMPRESSION=true
HTTP_ENABLE_REQUEST_ID=true
HTTP_ENABLE_RATE_LIMIT=false
HTTP_RATE_LIMIT_MAX=100
HTTP_RATE_LIMIT_DURATION=1m
HTTP_SHUTDOWN_TIMEOUT=30s
HTTP_DISABLE_STARTUP_MESSAGE=false
HTTP_ENABLE_STACK_TRACE=false
HTTP_ENABLE_METRICS=false
HTTP_ENABLE_HEALTH_CHECK=true
HTTP_HEALTH_CHECK_PATH=/health
HTTP_ENABLE_PPROF=false

# CORS
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID,X-Trace-ID
CORS_ALLOW_CREDENTIALS=false
CORS_EXPOSE_HEADERS=X-Request-ID,X-Trace-ID
CORS_MAX_AGE=3600

# TLS (optional)
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_MIN_VERSION=1.2

# Security
SECURITY_ENABLE_SECURITY_HEADERS=true
SECURITY_XSS_PROTECTION=1; mode=block
SECURITY_CONTENT_TYPE_NOSNIFF=nosniff
SECURITY_X_FRAME_OPTIONS=SAMEORIGIN
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_ENABLE_API_KEY_AUTH=false
SECURITY_API_KEY_HEADER=X-API-Key
